@page
@model IndexModel
@{
    ViewData["Title"] = "Perfil";
    ViewData["ActivePage"] = "Index";
}

<h3>Perfil</h3>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="form-group mb-3">
        <label for="Username" class="form-label">Usuario</label>
        <input asp-for="Username" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.PhoneNumber" class="form-label">Teléfono</label>
        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="11 1234-5678" />
        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
    </div>

    <button id="update-profile-button" type="submit" class="btn btn-primary">Guardar cambios</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
