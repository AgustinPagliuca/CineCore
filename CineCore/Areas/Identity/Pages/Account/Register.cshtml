@page
@model RegisterModel

@{
    ViewData["Title"] = "Registrarse";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <h1 class="mb-4 text-center">Crear cuenta</h1>

        <div class="card">
            <div class="card-body p-4">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="row">
                        <div class="col-sm-6 form-group mb-3">
                            <label asp-for="Input.Nombre" class="form-label">Nombre</label>
                            <input asp-for="Input.Nombre" class="form-control" placeholder="Agustín" />
                            <span asp-validation-for="Input.Nombre" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6 form-group mb-3">
                            <label asp-for="Input.Apellido" class="form-label">Apellido</label>
                            <input asp-for="Input.Apellido" class="form-control" placeholder="Pagliuca" />
                            <span asp-validation-for="Input.Apellido" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"
                               placeholder="tu@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-sm-6 form-group mb-3">
                            <label asp-for="Input.Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Input.Telefono" class="form-control" placeholder="11 1234-5678" />
                            <span asp-validation-for="Input.Telefono" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6 form-group mb-3">
                            <label asp-for="Input.FechaNacimiento" class="form-label">Fecha de nacimiento</label>
                            <input asp-for="Input.FechaNacimiento" class="form-control" type="date" />
                            <span asp-validation-for="Input.FechaNacimiento" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.Password" class="form-label">Contraseña</label>
                        <div class="input-group">
                            <input asp-for="Input.Password" class="form-control" id="registerPassword"
                                   autocomplete="new-password" aria-required="true"
                                   placeholder="Mínimo 6 caracteres" />
                            <button type="button" class="btn btn-outline-secondary"
                                    data-password-toggle="registerPassword"
                                    aria-label="Mostrar u ocultar contraseña">
                                <span class="toggle-mostrar">Mostrar</span>
                                <span class="toggle-ocultar" style="display:none;">Ocultar</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar contraseña</label>
                        <div class="input-group">
                            <input asp-for="Input.ConfirmPassword" class="form-control" id="registerPasswordConfirm"
                                   autocomplete="new-password" aria-required="true"
                                   placeholder="Repetí la contraseña" />
                            <button type="button" class="btn btn-outline-secondary"
                                    data-password-toggle="registerPasswordConfirm"
                                    aria-label="Mostrar u ocultar contraseña">
                                <span class="toggle-mostrar">Mostrar</span>
                                <span class="toggle-ocultar" style="display:none;">Ocultar</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid mb-3">
                        <button id="registerSubmit" type="submit" class="btn btn-primary">
                            Crear cuenta
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="mb-0">
                            <span class="text-muted small">¿Ya tenés cuenta?</span>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="small">
                                Iniciá sesión
                            </a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/cinecore-password.js" asp-append-version="true"></script>
}
