@model IEnumerable<CineCore.Models.Pelicula>

@{
    ViewData["Title"] = "Películas";
    var conFuncionesFuturas = ViewBag.IdsConFuncionesFuturas as HashSet<int> ?? new HashSet<int>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Películas</h1>
    @if (User.IsInRole(CineCore.Models.Roles.Empleado))
    {
        <a asp-action="Create" class="btn btn-primary">Nueva Película</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay películas cargadas.</div>
}
else
{
    <div class="row g-4">
        @foreach (var pelicula in Model)
        {
            var tienePoster = !string.IsNullOrWhiteSpace(pelicula.ImagenUrl);
            var enCartelera = conFuncionesFuturas.Contains(pelicula.Id);

            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="pelicula-card position-relative">
                    @if (!enCartelera)
                    {
                        <span class="pelicula-badge-proximamente">Próximamente</span>
                    }
                    <a asp-action="Details" asp-route-id="@pelicula.Id">
                        @if (tienePoster)
                        {
                            <img src="@pelicula.ImagenUrl" alt="Poster de @pelicula.Titulo" class="pelicula-poster" />
                        }
                        else
                        {
                            <div class="pelicula-poster-vacio">Sin imagen</div>
                        }
                    </a>
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@pelicula.Id"
                                   class="text-reset text-decoration-none stretched-link">
                                @pelicula.Titulo
                            </a>
                        </h5>
                        <p class="card-subtitle text-body-secondary mb-2 small">
                            @pelicula.Clasificacion · @Duracion.Format(pelicula.Duracion)
                        </p>
                        @if (pelicula.Generos.Any())
                        {
                            <p class="mb-0">
                                @foreach (var genero in pelicula.Generos)
                                {
                                    <span class="badge bg-secondary me-1">@genero.Nombre</span>
                                }
                            </p>
                        }

                        @if (User.IsInRole(CineCore.Models.Roles.Empleado))
                        {
                            <div class="mt-auto pt-3 position-relative" style="z-index: 2;">
                                <a asp-action="Edit" asp-route-id="@pelicula.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                                <a asp-action="Delete" asp-route-id="@pelicula.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
