@model CineCore.Models.TipoSala

@{
    ViewData["Title"] = "Eliminar tipo de sala";
}

<h1>Eliminar tipo de sala</h1>
<p class="alert alert-warning">¿Estás seguro de que querés eliminar este tipo de sala?</p>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Precio extra</dt>
            <dd class="col-sm-9">@Money.Format(Model.PrecioExtra)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
