@model CineCore.Models.TipoSala

@{
    ViewData["Title"] = "Editar tipo de sala";
}

<h1>Editar tipo de sala</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PrecioExtra" class="control-label"></label>
                @Html.EditorFor(m => m.PrecioExtra)
                <small class="form-text text-muted">Usá punto para decimales (ej: 2000.50). Poné 0 si no hay extra.</small>
                <span asp-validation-for="PrecioExtra" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
