@model CineCore.Models.TipoSala

@{
    ViewData["Title"] = "Editar tipo de sala";
}

<h1>Editar tipo de sala</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PrecioExtra" class="form-label"></label>
                <input asp-for="PrecioExtra" class="form-control" />
                <span asp-validation-for="PrecioExtra" class="text-danger"></span>
                <small class="form-text">
                    Importe que se suma al precio base de cada función en este tipo de sala.
                </small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
