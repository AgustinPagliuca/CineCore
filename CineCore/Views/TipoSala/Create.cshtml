@model CineCore.Models.TipoSala

@{
    ViewData["Title"] = "Nuevo tipo de sala";
}

<h1>Nuevo tipo de sala</h1>
<p class="text-muted mb-4">
    Cargá un nuevo tipo de sala (ej: 2D, 3D, IMAX) con su precio extra sobre el precio base de la función.
</p>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: 2D, 3D, IMAX" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PrecioExtra" class="form-label"></label>
                <input asp-for="PrecioExtra" class="form-control" placeholder="Ej: 2400.50" />
                <span asp-validation-for="PrecioExtra" class="text-danger"></span>
                <small class="form-text">
                    Importe que se suma al precio base de cada función en este tipo de sala.
                </small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Crear tipo</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
