@model IEnumerable<CineCore.Models.Sala>

@{
    ViewData["Title"] = "Salas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Salas</h1>
    <a asp-action="Create" class="btn btn-primary">Nueva Sala</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay salas cargadas.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Número</th>
                <th>Capacidad</th>
                <th>Tipo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sala in Model)
            {
                <tr>
                    <td>@sala.Numero</td>
                    <td>@sala.Capacidad butacas</td>
                    <td>@(sala.TipoSala?.Nombre ?? "-")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@sala.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                        <a asp-action="Details" asp-route-id="@sala.Id" class="btn btn-sm btn-outline-info">Detalle</a>
                        <a asp-action="Delete" asp-route-id="@sala.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
