@model CineCore.Models.Sala

@{
    ViewData["Title"] = $"Sala {Model.Numero}";
}

<h1>Sala @Model.Numero</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Número</dt>
            <dd class="col-sm-9">@Model.Numero</dd>

            <dt class="col-sm-3">Capacidad</dt>
            <dd class="col-sm-9">@Model.Capacidad butacas</dd>

            <dt class="col-sm-3">Tipo de sala</dt>
            <dd class="col-sm-9">@(Model.TipoSala?.Nombre ?? "-")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Editar</a>
    <a asp-action="Index" class="btn btn-outline-primary">Volver al listado</a>
</div>
