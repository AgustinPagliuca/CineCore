@model CineCore.Models.Sala

@{
    ViewData["Title"] = $"Eliminar sala {Model.Numero}";
    var funcionesAsociadas = ViewBag.FuncionesAsociadas as int? ?? 0;
}

<h1>Eliminar sala @Model.Numero</h1>

@if (funcionesAsociadas > 0)
{
    <div class="alert alert-warning">
        Esta sala tiene <strong>@funcionesAsociadas función/es asociada/s</strong>.
        No vas a poder eliminarla hasta que las elimines primero.
    </div>
}
else
{
    <p class="lead">¿Estás seguro de que querés eliminar esta sala? Esta acción no se puede deshacer.</p>
}

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Número</dt>
            <dd class="col-sm-9">@Model.Numero</dd>

            <dt class="col-sm-3">Capacidad</dt>
            <dd class="col-sm-9">@Model.Capacidad butacas</dd>

            <dt class="col-sm-3">Tipo de sala</dt>
            <dd class="col-sm-9">@(Model.TipoSala?.Nombre ?? "-")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger" @(funcionesAsociadas > 0 ? "disabled" : "")>Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
