@model CineCore.Models.Funcion

@{
    ViewData["Title"] = "Eliminar función";
}

<h1>Eliminar función</h1>

<p class="lead">¿Estás seguro de que querés eliminar esta función? Esta acción no se puede deshacer.</p>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Película</dt>
            <dd class="col-sm-9">@(Model.Pelicula?.Titulo ?? "-")</dd>

            <dt class="col-sm-3">Fecha y hora</dt>
            <dd class="col-sm-9">@Model.FechaHora.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Sala</dt>
            <dd class="col-sm-9">
                Sala @(Model.Sala?.Numero.ToString() ?? "-")
                @if (Model.Sala?.TipoSala != null)
                {
                    <span class="badge bg-info text-dark">@Model.Sala.TipoSala.Nombre</span>
                }
            </dd>

            <dt class="col-sm-3">Precio base</dt>
            <dd class="col-sm-9">@Money.Format(Model.Precio)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
