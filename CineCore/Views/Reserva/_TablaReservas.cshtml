@model CineCore.Models.ViewModels.TablaReservasContext

@{
    string BadgeClase(CineCore.Models.EstadoReserva estado) => estado switch
    {
        CineCore.Models.EstadoReserva.Confirmada => "bg-success",
        CineCore.Models.EstadoReserva.Pendiente => "bg-warning text-dark",
        CineCore.Models.EstadoReserva.Cancelada => "bg-secondary",
        _ => "bg-secondary"
    };

    var grupos = Model.Reservas
        .GroupBy(r => new { r.FuncionId, r.FechaReserva })
        .OrderByDescending(g => g.Key.FechaReserva)
        .ToList();
}

@if (!grupos.Any())
{
    <div class="alert alert-info mb-0">@Model.MensajeVacio</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Película</th>
                <th>Fecha y Hora</th>
                <th>Sala</th>
                <th>Butacas</th>
                <th>Total</th>
                <th>Estado</th>
                @if (Model.PermiteCancelar)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var grupo in grupos)
            {
                var primera = grupo.First();
                var funcion = primera.Funcion!;
                var butacas = grupo
                    .OrderBy(r => r.Butaca!.Fila)
                    .ThenBy(r => r.Butaca!.Numero)
                    .ToList();

                var activas = butacas
                    .Where(r => r.Estado != CineCore.Models.EstadoReserva.Cancelada)
                    .ToList();
                var todasCanceladas = !activas.Any();
                var estadoGrupo = todasCanceladas
                    ? CineCore.Models.EstadoReserva.Cancelada
                    : CineCore.Models.EstadoReserva.Confirmada;

                var total = activas.Sum(r => r.PrecioPagado);
                var totalOriginal = butacas.Sum(r => r.PrecioPagado);

                <tr>
                    <td>@funcion.Pelicula!.Titulo</td>
                    <td>@funcion.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>Sala @funcion.Sala!.Numero (@funcion.Sala.TipoSala!.Nombre)</td>
                    <td>
                        @string.Join(", ", butacas.Select(r => $"{r.Butaca!.Fila}{r.Butaca.Numero}"))
                        @if (butacas.Count > 1)
                        {
                            <br />
                            <small class="text-muted">@butacas.Count butacas</small>
                        }
                    </td>
                    <td>
                        @if (todasCanceladas)
                        {
                            <span class="text-muted text-decoration-line-through">@Money.Format(totalOriginal)</span>
                        }
                        else
                        {
                            <strong>@Money.Format(total)</strong>
                            @if (activas.Count != butacas.Count)
                            {
                                <br />
                                <small class="text-muted">
                                    (@(butacas.Count - activas.Count) cancelada@((butacas.Count - activas.Count) == 1 ? "" : "s"))
                                </small>
                            }
                        }
                    </td>
                    <td>
                        <span class="badge @BadgeClase(estadoGrupo)">@estadoGrupo</span>
                    </td>
                    @if (Model.PermiteCancelar)
                    {
                        <td>
                            @if (!todasCanceladas)
                            {
                                <form asp-action="CancelarGrupo" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Cancelar @(activas.Count == 1 ? "esta reserva" : $"las {activas.Count} butacas de esta reserva")?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="funcionId" value="@primera.FuncionId" />
                                    <input type="hidden" name="fecha" value="@primera.FechaReserva.ToString("o")" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Cancelar@(activas.Count > 1 ? " todo" : "")
                                    </button>
                                </form>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}
