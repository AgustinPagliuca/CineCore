@model IEnumerable<CineCore.Models.Reserva>

@{
    ViewData["Title"] = "Mis Reservas";
}

<h2>Mis Reservas</h2>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (!Model.Any())
{
    <p>No tenés reservas aún. <a asp-controller="Funcion" asp-action="Index">Ver funciones disponibles</a></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Película</th>
                <th>Fecha y Hora</th>
                <th>Sala</th>
                <th>Butaca</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Funcion.Pelicula.Titulo</td>
                    <td>@r.Funcion.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@r.Funcion.Sala.Numero</td>
                    <td>@r.Butaca.Fila - @r.Butaca.Numero</td>
                    <td>
                        <span class="badge @(r.Estado == "Confirmada" ? "bg-success" : "bg-secondary")">
                            @r.Estado
                        </span>
                    </td>
                    <td>
                        @if (r.Estado == "Confirmada")
                        {
                            <a asp-action="Cancelar" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('¿Cancelar esta reserva?')">
                                Cancelar
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}