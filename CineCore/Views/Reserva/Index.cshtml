@model IEnumerable<CineCore.Models.Reserva>

@{
    ViewData["Title"] = "Mis Reservas";

    string BadgeClase(CineCore.Models.EstadoReserva estado) => estado switch
    {
        CineCore.Models.EstadoReserva.Confirmada => "bg-success",
        CineCore.Models.EstadoReserva.Pendiente => "bg-warning text-dark",
        CineCore.Models.EstadoReserva.Cancelada => "bg-secondary",
        _ => "bg-secondary"
    };
}

<h2>Mis Reservas</h2>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <p>No tenés reservas aún. <a asp-controller="Funcion" asp-action="Index">Ver funciones disponibles</a></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Película</th>
                <th>Fecha y Hora</th>
                <th>Sala</th>
                <th>Butaca</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Funcion!.Pelicula!.Titulo</td>
                    <td>@r.Funcion.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@r.Funcion.Sala!.Numero</td>
                    <td>@r.Butaca!.Fila@r.Butaca.Numero</td>
                    <td>
                        <span class="badge @BadgeClase(r.Estado)">@r.Estado</span>
                    </td>
                    <td>
                        @if (r.Estado == CineCore.Models.EstadoReserva.Confirmada)
                        {
                            <form asp-action="Cancelar" asp-route-id="@r.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('¿Cancelar esta reserva?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Cancelar</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
