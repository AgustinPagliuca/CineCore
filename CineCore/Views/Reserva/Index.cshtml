@model CineCore.Models.ViewModels.MisReservasViewModel

@{
    ViewData["Title"] = "Mis Reservas";

    int ContarGrupos(IReadOnlyList<CineCore.Models.Reserva> reservas) =>
        reservas
            .GroupBy(r => new { r.FuncionId, r.FechaReserva })
            .Count();

    var cantidadProximas = ContarGrupos(Model.Proximas);
    var cantidadAnteriores = ContarGrupos(Model.Anteriores);
}

<h2>Mis Reservas</h2>

<ul class="nav nav-tabs mb-3" id="reservasTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab-proximas" data-bs-toggle="tab"
                data-bs-target="#panel-proximas" type="button" role="tab">
            Próximas
            <span class="badge bg-primary ms-1">@cantidadProximas</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-anteriores" data-bs-toggle="tab"
                data-bs-target="#panel-anteriores" type="button" role="tab">
            Anteriores
            <span class="badge bg-secondary ms-1">@cantidadAnteriores</span>
        </button>
    </li>
</ul>

<div class="tab-content" id="reservasTabsContent">
    <div class="tab-pane fade show active" id="panel-proximas" role="tabpanel">
        <partial name="_TablaReservas" model="@(new CineCore.Models.ViewModels.TablaReservasContext
                                               {
                                                   Reservas = Model.Proximas,
                                                   MensajeVacio = "No tenés reservas próximas. Mirá la cartelera para encontrar algo.",
                                                   PermiteCancelar = true
                                               })" />
    </div>

    <div class="tab-pane fade" id="panel-anteriores" role="tabpanel">
        <partial name="_TablaReservas" model="@(new CineCore.Models.ViewModels.TablaReservasContext
                                               {
                                                   Reservas = Model.Anteriores,
                                                   MensajeVacio = "Todavía no hay funciones pasadas en tu historial.",
                                                   PermiteCancelar = false
                                               })" />
    </div>
</div>
