@{
    ViewData["Title"] = "Elegí tu butaca";
    var funcion = ViewBag.Funcion as CineCore.Models.Funcion;
    var butacas = ViewBag.ButacasDisponibles as List<CineCore.Models.Butaca>;
}

<h2>Reservar - @funcion!.Pelicula!.Titulo</h2>

<div class="card mb-3">
    <div class="card-body">
        <p class="mb-1"><strong>Fecha:</strong> @funcion.FechaHora.ToString("dd/MM/yyyy HH:mm")</p>
        <p class="mb-1"><strong>Sala:</strong> @funcion.Sala!.Numero (@funcion.Sala.TipoSala!.Nombre)</p>
        <p class="mb-1">
            <strong>Precio:</strong> @Money.Format(funcion.PrecioFinal)
            @if (funcion.ExtraTipoSala > 0)
            {
                <small class="text-muted">
                    — @Money.Format(funcion.Precio) base + @Money.Format(funcion.ExtraTipoSala) por @funcion.Sala.TipoSala.Nombre
                </small>
            }
        </p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (butacas == null || !butacas.Any())
{
    <div class="alert alert-warning">No hay butacas disponibles para esta función.</div>
}
else
{
    <h4>Seleccioná una butaca:</h4>
    <form method="post" asp-action="Crear">
        @Html.AntiForgeryToken()
        <input type="hidden" name="funcionId" value="@funcion.Id" />
        <div class="row">
            @foreach (var butaca in butacas)
            {
                <div class="col-md-1 mb-2">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="butacaId"
                               value="@butaca.Id" id="b@(butaca.Id)" required />
                        <label class="form-check-label" for="b@(butaca.Id)">
                            @butaca.Fila@butaca.Numero
                        </label>
                    </div>
                </div>
            }
        </div>
        <button type="submit" class="btn btn-primary mt-3">Confirmar reserva por @Money.Format(funcion.PrecioFinal)</button>
        <a asp-controller="Funcion" asp-action="Index" class="btn btn-secondary mt-3">Volver</a>
    </form>
}
