<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineCore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/butacas.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CineCore.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CineCore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @using Microsoft.AspNetCore.Identity
                    @inject SignInManager<CineCore.Models.ApplicationUser> SignInManager

<li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Pelicula" asp-action="Index">Películas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Funcion" asp-action="Index">Cartelera</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User) && User.IsInRole(CineCore.Models.Roles.Empleado))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-white dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    Administración
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Genero" asp-action="Index">Géneros</a></li>
                                    <li><a class="dropdown-item" asp-controller="TipoSala" asp-action="Index">Tipos de Sala</a></li>
                                    <li><a class="dropdown-item" asp-controller="Pelicula" asp-action="Index">Películas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Sala" asp-action="Index">Salas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Funcion" asp-action="Index">Funciones</a></li>
                                </ul>
                            </li>
                        }
                        @if (SignInManager.IsSignedIn(User) && User.IsInRole(CineCore.Models.Roles.Cliente))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Reserva" asp-action="Index">Mis Reservas</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CineCore - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
