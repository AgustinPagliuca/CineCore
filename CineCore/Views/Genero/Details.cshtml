@model CineCore.Models.Genero

@{
    ViewData["Title"] = "Detalles del género";
}

<h1>@Model.Nombre</h1>

<div class="card mt-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción." : Model.Descripcion)
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2 mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Editar</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>
